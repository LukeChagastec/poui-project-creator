{
  "name": "poui-project-creator",
  "displayName": "PO UI Project Creator",
  "description": "Cria e configura um novo projeto Angular com PO UI e Protheus.",
  "version": "0.0.7",
  "icon": "images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chagastec/poui-project-creator.git"
  },
  "license": "MIT",
  "publisher": "Chagastec",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:poui-project-creator.createProject"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "poui-project-creator.createProject",
        "title": "PO UI: Criar Novo Projeto Protheus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node node_modules/@vscode/test-cli/out/bin.mjs"
  },
  "devDependencies": {
    
    "@types/mocha": "^10.0.10",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.39.0",
    "glob": "^11.0.3",
    "mocha": "^11.7.2",
    "typescript": "^5.0.4"
  }
}
